geLink_page$normalization.graphql"},"__module_component_CometTextWithEntitiesRelay_textWithEntities":{"__dr":"PagesCometPageLink.react"},"category_type":"SOFTWARE_COMPANY","verification_status":"NOT_VERIFIED","is_verified":false,"profile_url":"https:\/\/www.facebook.com\/w3codevs\/","mobileUrl":"https:\/\/m.facebook.com\/w3codevs\/","__isNode":"Page"},"entity_is_weak_reference":false,"length":8,"offset":2},{"entity":{"__typename":"Group","__isEntity":"Group","__isActor":"Group","id":"2617114955272389","url":"https:\/\/www.facebook.com\/groups\/w3codevs\/","profile_url":"https:\/\/www.facebook.com\/groups\/w3codevs\/","work_foreign_entity_info":null,"work_official_status":"UNOFFICIAL","mobileUrl":"https:\/\/m.facebook.com\/groups\/w3codevs\/","__isNode":"Group"},"entity_is_weak_reference":false,"length":18,"offset":690},{"entity":{"__typename":"Group","__isEntity":"Group","__isActor":"Group","id":"2617114955272389","url":"https:\/\/www.facebook.com\/groups\/w3codevs\/","profile_url":"https:\/\/www.facebook.com\/groups\/w3codevs\/","work_foreign_entity_info":null,"work_official_status":"UNOFFICIAL","mobileUrl":"https:\/\/m.facebook.com\/groups\/w3codevs\/","__isNode":"Group"},"entity_is_weak_reference":false,"length":18,"offset":2981},{"entity":{"__typename":"Group","__isEntity":"Group","__isActor":"Group","id":"2617114955272389","url":"https:\/\/www.facebook.com\/groups\/w3codevs\/","profile_url":"https:\/\/www.facebook.com\/groups\/w3codevs\/","work_foreign_entity_info":null,"work_official_status":"UNOFFICIAL","mobileUrl":"https:\/\/m.facebook.com\/groups\/w3codevs\/","__isNode":"Group"},"entity_is_weak_reference":false,"length":36,"offset":2922}],"color_ranges":[],"text":"\ud83d\udce3 W3codevs \u098f\u09b0 \u09aa\u0995\u09cd\u09b7 \u09a5\u09c7\u0995\u09c7 \u099b\u09df\u09ae\u09be\u09b8 \u09ac\u09cd\u09af\u09be\u09aa\u09c0 \u09b8\u09ae\u09cd\u09aa\u09c2\u09b0\u09cd\u09a3 \u09ac\u09bf\u09a8\u09be\u09ae\u09c2\u09b2\u09cd\u09af\u09c7 \u0985\u09a8\u09b2\u09be\u0987\u09a8 \u09aa\u09cd\u09b0\u09b6\u09bf\u0995\u09cd\u09b7\u09a3\u0964\n\n\ud83d\udce3 Cyber Security & Ethical Hacking (All in One\u270c\ufe0f)\n\n\ud83d\udc49 \u098f\u0995\u099c\u09a8 \u09aa\u09cd\u09b0\u09ab\u09c7\u09b6\u09a8\u09be\u09b2 \u0987\u09a5\u09bf\u0995\u09cd\u09af\u09be\u09b2 \u09b9\u09cd\u09af\u09be\u0995\u09be\u09b0 \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u09a8\u09bf\u099c\u09c7\u09b0 \u0995\u09cd\u09af\u09be\u09b0\u09bf\u09df\u09be\u09b0 \u0997\u09dc\u09a4\u09c7 \u0986\u09aa\u09a8\u09be\u09b0 \u09af\u09c7 \u09b8\u0995\u09b2 \u09ac\u09bf\u09b7\u09df \u099c\u09be\u09a8\u09be \u09a6\u09b0\u0995\u09be\u09b0, \u09af\u09c7\u0987 \u09b8\u0995\u09b2 \u09b8\u09cd\u0995\u09bf\u09b2 \u0986\u09aa\u09a8\u09be\u09b0 \u09a5\u09be\u0995\u09a4\u09c7 \u09b9\u09ac\u09c7 \u09a4\u09be\u09b0 \u09b8\u09ac \u0995\u09bf\u099b\u09c1 \u098f\u0987 \u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09ae\u09a7\u09cd\u09af\u09c7 \u0986\u09ae\u09b0\u09be \u09b6\u09bf\u0996\u09be\u09ac\u0964 \u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u099c\u09df\u09c7\u09a8 \u0995\u09b0\u09be\u09b0 \u09aa\u09b0 \u09aa\u09b0\u09cd\u09af\u09be\u09df\u0995\u09cd\u09b0\u09ae\u09c7 \u0985\u09b8\u0982\u0996\u09cd\u09af \u09aa\u09cd\u09b0\u09bf\u09ae\u09bf\u09df\u09be\u09ae \u099f\u09c1\u09b2\u09b8 \u098f\u09b0 \u098f\u0995\u09cd\u09b8\u09c7\u09b8 \u098f\u0995\u09a6\u09ae \u09ab\u09cd\u09b0\u09bf\u09a4\u09c7 \u09aa\u09c7\u09df\u09c7 \u09af\u09be\u09ac\u09c7\u09a8 \ud83d\ude42 \u098f\u09ac\u0982 \u09aa\u09be\u09b6\u09be\u09aa\u09be\u09b6\u09bf \u0987\u09a5\u09bf\u0995\u09cd\u09af\u09be\u09b2 \u09b9\u09cd\u09af\u09be\u0995\u09bf\u0982 \u0995\u09b0\u09c7 \u09b8\u09ae\u09cd\u09aa\u09c2\u09b0\u09cd\u09a3 \u09b2\u09bf\u0997\u09cd\u09af\u09be\u09b2 \u09ad\u09be\u09ac\u09c7 \u0987\u09a8\u0995\u09be\u09ae \u0995\u09b0\u09be\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae \u09a4 \u09a5\u09be\u0995\u099b\u09c7\u0987\u0964 \u0986\u09ae\u09be\u09b0 \u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8 \u0986\u09aa\u09a8\u09bf \u098f\u0987 \u098f\u0995\u099f\u09bf \u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09b8\u09bf\u09b2\u09c7\u09ac\u09be\u09b8\u09c7 \u098f\u0995\u09b8\u09be\u09a5\u09c7 \u09af\u09be \u09aa\u09be\u099a\u09cd\u099b\u09c7\u09a8 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09e7\u09e6 \u099f\u09be \u09aa\u09cd\u09b0\u09bf\u09ae\u09bf\u09df\u09be\u09ae \u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09b8\u09bf\u09b2\u09c7\u09ac\u09be\u09b8 \u098f\u0995\u09b8\u09be\u09a5\u09c7 \u0995\u09b0\u09b2\u09c7\u0993 \u09a4\u09be \u09aa\u09be\u09ac\u09c7\u09a8 \u09a8\u09be\u0964\n\n\ud83d\udc49 \u0995\u09cb\u09b0\u09cd\u09b8 \u09b6\u09c7\u09b7\u09c7 \u09a6\u0995\u09cd\u09b7 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u09a8\u09bf\u09df\u09c7 \u09b8\u09cd\u09aa\u09c7\u09b6\u09be\u09b2 \u099f\u09c0\u09ae \u09a4\u09c8\u09b0\u09bf \u0995\u09b0\u09be \u09b9\u09ac\u09c7, \u098f\u09ac\u0982 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09b0\u09be W3codevs Community \u099f\u09c0\u09ae\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7\u0987 \u0995\u09be\u099c \u0995\u09b0\u09be\u09b0 \u09b8\u09c1\u09af\u09cb\u0997 \u09aa\u09be\u09ac\u09c7\u0964\n\n\ud83d\udc49 \u09a4\u09be\u0987 \u0986\u09b0 \u09a6\u09c7\u09b0\u09bf \u09a8\u09be \u0995\u09b0\u09c7 \u098f\u0996\u09a8\u0987 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u099c\u09df\u09c7\u09a8 \u0995\u09b0\u09c1\u09a8 \u098f\u09ac\u0982 \u09a8\u09bf\u099c\u09c7\u0995\u09c7 \u0997\u09dc\u09c7 \u09a4\u09c1\u09b2\u09c1\u09a8 \u098f\u0995\u099c\u09a8 \u09b8\u09ab\u09b2 \u0987\u09a5\u09bf\u0995\u09cd\u09af\u09be\u09b2 \u09b9\u09cd\u09af\u09be\u0995\u09be\u09b0 \u098f\u09ac\u0982 \u09b8\u09be\u0987\u09ac\u09be\u09b0 \u09b8\u09bf\u0995\u09bf\u0989\u09b0\u09bf\u099f\u09bf \u098f\u0995\u09cd\u09b8\u09aa\u09be\u09b0\u09cd\u099f \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7\u0964\n\n\u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09a7\u09b0\u09a8\u0983 \u0985\u09a8\u09b2\u09be\u0987\u09a8 \u09b2\u09be\u0987\u09ad \u0995\u09cd\u09b2\u09be\u09b8 (\u099c\u09c1\u09ae \u09aa\u09cd\u09b0\u09cb \u09b8\u09ab\u099f\u0993\u09df\u09cd\u09af\u09be\u09b0 \u098f\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7)\n\u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09ae\u09c7\u09df\u09be\u09a6\u0995\u09be\u09b2\u0983 \u09ec \u09ae\u09be\u09b8 (\u09b8\u09aa\u09cd\u09a4\u09be\u09b9\u09c7 \u09e9 \u099f\u09bf \u0995\u09cd\u09b2\u09be\u09b8)\n\u0995\u09cd\u09b2\u09be\u09b8\u09c7\u09b0 \u09b8\u09ae\u09df\u0983 \u09b0\u09be\u09a4 \u09ef.\u09e6\u09e6 - \u09e7\u09e7.\u09e6\u09e6 \u099f\u09be\n\n\u2705\u2705\u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u0995\u09bf \u0995\u09bf \u09b6\u09c7\u0996\u09be\u09a8\u09cb \u09b9\u09ac\u09c7\u0983\u2705\u2705\n\n\ud83d\udd30 1. Basic of Hacking & Career as a Hacker.\n\ud83d\udd30 2. Google Hacking Fundamentals for Hacker.\n\ud83d\udd30 3. All Free & Premium Hacking Tools Details Discussion.\n\ud83d\udd30 4. Deep web & Dark web (Advance tips & tricks).\n\ud83d\udd30 5. Setting up Hacking Lab & Environment.\n\ud83d\udd30 6. Kali Linux Fundamentals for Hackers.\n\ud83d\udd30 7. Parrot Security Fundamentals for Hackers.\n\ud83d\udd30 8. Windows Server Fundamentals for Hackers.\n\ud83d\udd30 9. Kali Linux Shell Scripting for Hackers.\n\ud83d\udd30 10. Network Hacking.\n\ud83d\udd30 11. WiFi Network Hacking & Security.\n\ud83d\udd30 12. Social Engineering.\n\ud83d\udd30 13. Information Gathering & Footprinting.\n\ud83d\udd30 14. System Exploitation.\n\ud83d\udd30 15. SQL Injection All Methods.\n\ud83d\udd30 16. Gaining Access: server side attack.\n\ud83d\udd30 17. Gaining Access: client side attack.\n\ud83d\udd30 18. Client Side Attack Using Social Engineering.\n\ud83d\udd30 19. Website Hacking & Security (Advance tips & tricks).\n\ud83d\udd30 20. WordPress Website Hacking & Security (Advance tips & tricks).\n\ud83d\udd30 21. Information Tracking Using Number.\n\ud83d\udd30 22. Malware Making & Threats (virus).\n\ud83d\udd30 23. Hacking Device Making.\n\ud83d\udd30 24. Windows Attack.\n\ud83d\udd30 25. Hack Bank Account via-APT Attack.\n\ud83d\udd30 26. Black Hat Approach to Hacking.\n\n\u09ac\u09cb\u09a8\u09be\u09b8 \u0995\u09cd\u09b2\u09be\u09b8\u0983 Facebook Security & Ethical Hacking.\n\n\ud83d\ude42............\u0986\u09b0\u0993 \u0985\u09a8\u09c7\u0995 \u0995\u09bf\u099b\u09c1............\ud83d\ude42\n\n\u2753\u2753 \u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u099c\u09df\u09c7\u09a8 \u0995\u09b0\u09be\u09b0 \u09b6\u09b0\u09cd\u09a4\u0983\u2753\u2753\n\n\ud83d\udc49 \u09e7\u09eb \u09a8\u09ad\u09c7\u09ae\u09cd\u09ac\u09b0 \u09a5\u09c7\u0995\u09c7 \u0995\u09cd\u09b2\u09be\u09b8 \u09b6\u09c1\u09b0\u09c1 \u09b9\u09ac\u09c7\u0964 \u09a8\u09bf\u09df\u09ae\u09bf\u09a4 \u09b2\u09be\u0987\u09ad \u0995\u09cd\u09b2\u09be\u09b8\u09c7 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u09a5\u09be\u0995\u09a4\u09c7 \u09b9\u09ac\u09c7 \u098f\u09ac\u0982 \u09b9\u09cb\u09ae\u0993\u09df\u09be\u09b0\u09cd\u0995 \u0997\u09c1\u09b2\u09cb \u0997\u09cd\u09b0\u09c1\u09aa\u09c7 \u099c\u09ae\u09be \u09a6\u09bf\u09a4\u09c7 \u09b9\u09ac\u09c7\n\n\ud83d\udc49 \u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09af\u09be\u09ac\u09a4\u09c0\u09df \u0996\u09b0\u099a \u09aa\u09b0\u09bf\u099a\u09be\u09b2\u09a8\u09be \u0995\u09b0\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u0996\u09c1\u09ac\u0987 \u09b8\u09be\u09ae\u09be\u09a8\u09cd\u09af \u09b0\u09c7\u099c\u09bf\u09b7\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u09ab\u09bf \u09a8\u09c7\u0993\u09df\u09be \u09b9\u09ac\u09c7\u0964 \u0995\u09bf\u099b\u09c1 \u09ac\u09be\u099c\u09c7, \u0985\u09a8\u09bf\u09df\u09ae\u09bf\u09a4, \u0986\u0997\u09be\u099b\u09be \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0, \u09ab\u09cd\u09b0\u09bf \u09aa\u09be\u0987\u09df\u09be \u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u099c\u09df\u09c7\u09a8 \u0995\u09b0\u09c7 & \u09ac\u09bf\u09b6\u09c3\u0999\u09cd\u0996\u09b2\u09be \u09a4\u09c8\u09b0\u09c0 \u0995\u09b0\u09c7 \u09b8\u09ac\u09be\u09b0 \u09ae\u09be\u099d\u09c7\u0964 \u098f\u0987 \u0985\u09ae\u09a8\u09cb\u09af\u09cb\u0997\u09c0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u09ad\u09be\u09b2\u09cb \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09b0\u09be \u09b8\u09c1\u09af\u09cb\u0997 \u09aa\u09be\u09df \u09a8\u09be \u0995\u09cb\u09b0\u09cd\u09b8 \u0995\u09b0\u09be\u09b0\u0964 \u09b0\u09c7\u099c\u09bf\u09b7\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u09ab\u09bf \u09a8\u09bf\u099a\u09cd\u099b\u09bf \u09b6\u09c1\u09a7\u09c1\u09ae\u09be\u09a4\u09cd\u09b0 \u09b8\u09bf\u09b0\u09bf\u09df\u09be\u09b8 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u09b8\u09c1\u09af\u09cb\u0997 \u09a6\u09c7\u0993\u09df\u09be\u09b0 \u099c\u09a8\u09cd\u09af, \u099f\u09be\u0995\u09be \u09aa\u09df\u09b8\u09be\u09b0 \u09ac\u09bf\u09b7\u09df \u09a5\u09be\u0995\u09b2\u09c7 \u09ac\u0996\u09be\u099f\u09c7 \u0997\u09c1\u09b2\u09cb \u0986\u09b0 \u0995\u09c7\u09be\u09b0\u09cd\u09b8\u09c7 \u099c\u09df\u09c7\u09a8 \u0995\u09b0\u09ac\u09c7 \u09a8\u09be\u0964\n\n\ud83d\udc49 \u0986\u09aa\u09a8\u09bf \u0995\u09cb\u09b0\u09cd\u09b8\u099f\u09bf \u0995\u09b0\u09a4\u09c7 \u099a\u09be\u0987\u09b2\u09c7 \u09aa\u09c7\u099c\u09c7 \u09ae\u09c7\u09b8\u09c7\u099c \u09a6\u09bf\u09a8 \u0985\u09a5\u09ac\u09be \u0995\u09ae\u09c7\u09a8\u09cd\u099f \u0995\u09b0\u09c1\u09a8 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u099f\u09bf\u09ae \u09ae\u09c7\u09ae\u09cd\u09ac\u09be\u09b0 \u0986\u09aa\u09a8\u09be\u09b0 \u0987\u09a8\u09ac\u0995\u09cd\u09b8\u09c7 \u09ae\u09c7\u09b8\u09c7\u099c \u09a6\u09bf\u09df\u09c7 \u09ac\u09bf\u09b8\u09cd\u09a4\u09be\u09b0\u09bf\u09a4 \u099c\u09be\u09a8\u09be\u09ac\u09c7\u09a8 \u0964 (\u0986\u09b8\u09a8 \u09b8\u0982\u0996\u09cd\u09af\u09be \u09b8\u09c0\u09ae\u09bf\u09a4)\n\n\ud83d\udc49\ud83d\udc49 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ab\u09c7\u09b8\u09ac\u09c1\u0995 \u0997\u09cd\u09b0\u09c1\u09aa \u09b2\u09bf\u0982\u0995\u0983 https:\/\/facebook.com\/groups\/w3codevs\n\n\u0986\u09b0\u09c7\u09be \u09ac\u09bf\u09b8\u09cd\u09a4\u09be\u09b0\u09bf\u09a4 \u099c\u09be\u09a8\u09a4\u09c7 W3codevs Community \u0997\u09cd\u09b0\u09c1\u09aa\u09c7 \u099c\u09af\u09bc\u09c7\u09a8 \u0995\u09b0\u09c1\u09a8\u0964\n\n\ud83d\udc49\ud83d\udc49\u09aa\u09cd\u09b0\u09af\u09bc\u09c7\u09be\u099c\u09a8\u09c7 \u0995\u09b2 \u0995\u09b0\u09c1\u09a8 - 01752215939, 01790262300, 01568830767\n\n\u0986\u09aa\u09a8\u09bf \u0986\u09aa\u09a8\u09be\u09b0 \u09ab\u09c7\u09b8\u09ac\u09c1\u0995 \u09ac\u09a8\u09cd\u09a7\u09c1\u09a6\u09c7\u09b0\u0995\u09c7 \u0995\u09ae\u09c7\u09a8\u09cd\u099f \u09ac\u0995\u09cd\u09b8\u09c7 \u09ae\u09c7\u09a8\u09b8\u09a8 \u0995\u09b0\u09c7 \u09a6\u09bf\u09a8, \u09b9\u09df\u09a4 \u0986\u09aa\u09a8\u09be\u09b0 \u098f\u0987 \u0995\u09ae\u09c7\u09a8\u09cd\u099f \u0986\u09aa\u09a8\u09be\u09b0 \u09ac\u09a8\u09cd\u09a7\u09c1\u09b0 \u09ac\u09c7\u0995\u09be\u09b0\u09a4\u09cd\u09ac \u09a6\u09c1\u09b0 \u0995\u09b0\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u0964\n\n(\u09ac\u09bf\u0983\u09a6\u09cd\u09b0\u0983 \u098f\u0987 \u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09ae\u09c2\u09b2 \u0989\u09a6\u09cd\u09a6\u09c7\u09b6\u09cd\u09af \u09b9\u09b2, \u09b8\u0995\u09b2\u09c7 \u09af\u09be\u09a4\u09c7 \u09b8\u09be\u0987\u09ac\u09be\u09b0 \u09b8\u09bf\u0995\u09bf\u0989\u09b0\u09bf\u099f\u09bf \u09b8\u09ae\u09cd\u09aa\u09b0\u09cd\u0995\u09c7 \u099c\u09be\u09a8\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 \u098f\u09ac\u0982 \u0987\u09a5\u09bf\u0995\u09be\u09b2 \u09b9\u09cd\u09af\u09be\u0995\u09bf\u0982 \u09b6\u09bf\u0996\u09be\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u09a8\u09bf\u099c\u09c7\u09b0 \u0995\u09cd\u09af\u09be\u09b0\u09bf\u09df\u09be\u09b0 \u0997\u09dc\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 \u098f\u09ac\u0982 \u09a6\u09c7\u09b6 \u0993 \u099c\u09be\u09a4\u09bf\u09b0 \u09ae\u0999\u09cd\u0997\u09b2\u09c7 \u098f\u0987 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u0995\u09c7 \u0995\u09be\u099c\u09c7 \u09b2\u09be\u0997\u09be\u09df\u0964 \u0995\u09c7\u0989 \u098f\u0987 \u0995\u09cb\u09b0\u09cd\u09b8 \u0995\u09b0\u09be\u09b0 \u09aa\u09b0 \u0995\u09cb\u09a8 \u09aa\u09cd\u09b0\u0995\u09be\u09b0 \u0985\u09ac\u09c8\u09a7 \u09b9\u09cd\u09af\u09be\u0995\u09bf\u0982 \u098f\u09ac\u0982 \u0985\u09a8\u09c8\u09a4\u09bf\u0995 \u0995\u09cb\u09a8 \u0995\u09be\u099c \u0995\u09b0\u09c7 \u09a5\u09be\u0995\u09b2\u09c7 \u09ac\u09be \u09b8\u09ae\u09cd\u09aa\u09c3\u0995\u09cd\u09a4 \u09a5\u09be\u0995\u09b2\u09c7 \u09a4\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09aa\u09cd\u09b0\u09b6\u09bf\u0995\u09cd\u09b7\u0995 \u0995\u09cb\u09a8 \u09ad\u09be\u09ac\u09c7 \u09a6\u09be\u09df\u09c0 \u09a5\u09be\u0995\u09ac\u09c7 \u09a8\u09be)"},"message_truncation_line_limit":null,"id":"UzpfSTEwNzg5MTE1NDI3MzA4Nzo0MTU5MjM4OTY4MDMxNDM="},"__module_operation_CometFeedStoryMessageSection_story":{"__dr":"CometFeedStoryDefaultMessageRenderingStrategy_message$normalization.graphql"},"__module_component_CometFeedStoryMessageSection_story":{"__dr":"CometFeedStoryDefaultMessageRenderingStrategy.react"}},"message_suffix":null,"message_container":{"__typename":"CometFeedStoryMessageContainerRenderingStrategy","__isICometStorySection":"CometFeedStoryMessageContainerRenderingStrategy","is_prod_eligible":true,"story":{"message":{"text":"\ud83d\udce3 W3codevs \u098f\u09b0 \u09aa\u0995\u09cd\u09b7 \u09a5\u09c7\u0995\u09c7 \u099b\u09df\u09ae\u09be\u09b8 \u09ac\u09cd\u09af\u09be\u09aa\u09c0 \u09b8\u09ae\u09cd\u09aa\u09c2\u09b0\u09cd\u09a3 \u09ac\u09bf\u09a8\u09be\u09ae\u09c2\u09b2\u09cd\u09af\u09c7 \u0985\u09a8\u09b2\u09be\u0987\u09a8 \u09aa\u09cd\u09b0\u09b6\u09bf\u0995\u09cd\u09b7\u09a3\u0964\n\n\ud83d\udce3 Cyber Security & Ethical Hacking (All in One\u270c\ufe0f)\n\n\ud83d\udc49 \u098f\u0995\u099c\u09a8 \u09aa\u09cd\u09b0\u09ab\u09c7\u09b6\u09a8\u09be\u09b2 \u0987\u09a5\u09bf\u0995\u09cd\u09af\u09be\u09b2 \u09b9\u09cd\u09af\u09be\u0995\u09be\u09b0 \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u09a8\u09bf\u099c\u09c7\u09b0 \u0995\u09cd\u09af\u09be\u09b0\u09bf\u09df\u09be\u09b0 \u0997\u09dc\u09a4\u09c7 \u0986\u09aa\u09a8\u09be\u09b0 \u09af\u09c7 \u09b8\u0995\u09b2 \u09ac\u09bf\u09b7\u09df \u099c\u09be\u09a8\u09be \u09a6\u09b0\u0995\u09be\u09b0, \u09af\u09c7\u0987 \u09b8\u0995\u09b2 \u09b8\u09cd\u0995\u09bf\u09b2 \u0986\u09aa\u09a8\u09be\u09b0 \u09a5\u09be\u0995\u09a4\u09c7 \u09b9\u09ac\u09c7 \u09a4\u09be\u09b0 \u09b8\u09ac \u0995\u09bf\u099b\u09c1 \u098f\u0987 \u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09ae\u09a7\u09cd\u09af\u09c7 \u0986\u09ae\u09b0\u09be \u09b6\u09bf\u0996\u09be\u09ac\u0964 \u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u099c\u09df\u09c7\u09a8 \u0995\u09b0\u09be\u09b0 \u09aa\u09b0 \u09aa\u09b0\u09cd\u09af\u09be\u09df\u0995\u09cd\u09b0\u09ae\u09c7 \u0985\u09b8\u0982\u0996\u09cd\u09af \u09aa\u09cd\u09b0\u09bf\u09ae\u09bf\u09df\u09be\u09ae \u099f\u09c1\u09b2\u09b8 \u098f\u09b0 \u098f\u0995\u09cd\u09b8\u09c7\u09b8 \u098f\u0995\u09a6\u09ae \u09ab\u09cd\u09b0\u09bf\u09a4\u09c7 \u09aa\u09c7\u09df\u09c7 \u09af\u09be\u09ac\u09c7\u09a8 \ud83d\ude42 \u098f\u09ac\u0982 \u09aa\u09be\u09b6\u09be\u09aa\u09be\u09b6\u09bf \u0987\u09a5\u09bf\u0995\u09cd\u09af\u09be\u09b2 \u09b9\u09cd\u09af\u09be\u0995\u09bf\u0982 \u0995\u09b0\u09c7 \u09b8\u09ae\u09cd\u09aa\u09c2\u09b0\u09cd\u09a3 \u09b2\u09bf\u0997\u09cd\u09af\u09be\u09b2 \u09ad\u09be\u09ac\u09c7 \u0987\u09a8\u0995\u09be\u09ae \u0995\u09b0\u09be\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae \u09a4 \u09a5\u09be\u0995\u099b\u09c7\u0987\u0964 \u0986\u09ae\u09be\u09b0 \u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8 \u0986\u09aa\u09a8\u09bf \u098f\u0987 \u098f\u0995\u099f\u09bf \u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09b8\u09bf\u09b2\u09c7\u09ac\u09be\u09b8\u09c7 \u098f\u0995\u09b8\u09be\u09a5\u09c7 \u09af\u09be \u09aa\u09be\u099a\u09cd\u099b\u09c7\u09a8 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09e7\u09e6 \u099f\u09be \u09aa\u09cd\u09b0\u09bf\u09ae\u09bf\u09df\u09be\u09ae \u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09b8\u09bf\u09b2\u09c7\u09ac\u09be\u09b8 \u098f\u0995\u09b8\u09be\u09a5\u09c7 \u0995\u09b0\u09b2\u09c7\u0993 \u09a4\u09be \u09aa\u09be\u09ac\u09c7\u09a8 \u09a8\u09be\u0964\n\n\ud83d\udc49 \u0995\u09cb\u09b0\u09cd\u09b8 \u09b6\u09c7\u09b7\u09c7 \u09a6\u0995\u09cd\u09b7 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u09a8\u09bf\u09df\u09c7 \u09b8\u09cd\u09aa\u09c7\u09b6\u09be\u09b2 \u099f\u09c0\u09ae \u09a4\u09c8\u09b0\u09bf \u0995\u09b0\u09be \u09b9\u09ac\u09c7, \u098f\u09ac\u0982 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09b0\u09be W3codevs Community \u099f\u09c0\u09ae\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7\u0987 \u0995\u09be\u099c \u0995\u09b0\u09be\u09b0 \u09b8\u09c1\u09af\u09cb\u0997 \u09aa\u09be\u09ac\u09c7\u0964\n\n\ud83d\udc49 \u09a4\u09be\u0987 \u0986\u09b0 \u09a6\u09c7\u09b0\u09bf \u09a8\u09be \u0995\u09b0\u09c7 \u098f\u0996\u09a8\u0987 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u099c\u09df\u09c7\u09a8 \u0995\u09b0\u09c1\u09a8 \u098f\u09ac\u0982 \u09a8\u09bf\u099c\u09c7\u0995\u09c7 \u0997\u09dc\u09c7 \u09a4\u09c1\u09b2\u09c1\u09a8 \u098f\u0995\u099c\u09a8 \u09b8\u09ab\u09b2 \u0987\u09a5\u09bf\u0995\u09cd\u09af\u09be\u09b2 \u09b9\u09cd\u09af\u09be\u0995\u09be\u09b0 \u098f\u09ac\u0982 \u09b8\u09be\u0987\u09ac\u09be\u09b0 \u09b8\u09bf\u0995\u09bf\u0989\u09b0\u09bf\u099f\u09bf \u098f\u0995\u09cd\u09b8\u09aa\u09be\u09b0\u09cd\u099f \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7\u0964\n\n\u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09a7\u09b0\u09a8\u0983 \u0985\u09a8\u09b2\u09be\u0987\u09a8 \u09b2\u09be\u0987\u09ad \u0995\u09cd\u09b2\u09be\u09b8 (\u099c\u09c1\u09ae \u09aa\u09cd\u09b0\u09cb \u09b8\u09ab\u099f\u0993\u09df\u09cd\u09af\u09be\u09b0 \u098f\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7)\n\u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09ae\u09c7\u09df\u09be\u09a6\u0995\u09be\u09b2\u0983 \u09ec \u09ae\u09be\u09b8 (\u09b8\u09aa\u09cd\u09a4\u09be\u09b9\u09c7 \u09e9 \u099f\u09bf \u0995\u09cd\u09b2\u09be\u09b8)\n\u0995\u09cd\u09b2\u09be\u09b8\u09c7\u09b0 \u09b8\u09ae\u09df\u0983 \u09b0\u09be\u09a4 \u09ef.\u09e6\u09e6 - \u09e7\u09e7.\u09e6\u09e6 \u099f\u09be\n\n\u2705\u2705\u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u0995\u09bf \u0995\u09bf \u09b6\u09c7\u0996\u09be\u09a8\u09cb \u09b9\u09ac\u09c7\u0983\u2705\u2705\n\n\ud83d\udd30 1. Basic of Hacking & Career as a Hacker.\n\ud83d\udd30 2. Google Hacking Fundamentals for Hacker.\n\ud83d\udd30 3. All Free & Premium Hacking Tools Details Discussion.\n\ud83d\udd30 4. Deep web & Dark web (Advance tips & tricks).\n\ud83d\udd30 5. Setting up Hacking Lab & Environment.\n\ud83d\udd30 6. Kali Linux Fundamentals for Hackers.\n\ud83d\udd30 7. Parrot Security Fundamentals for Hackers.\n\ud83d\udd30 8. Windows Server Fundamentals for Hackers.\n\ud83d\udd30 9. Kali Linux Shell Scripting for Hackers.\n\ud83d\udd30 10. Network Hacking.\n\ud83d\udd30 11. WiFi Network Hacking & Security.\n\ud83d\udd30 12. Social Engineering.\n\ud83d\udd30 13. Information Gathering & Footprinting.\n\ud83d\udd30 14. System Exploitation.\n\ud83d\udd30 15. SQL Injection All Methods.\n\ud83d\udd30 16. Gaining Access: server side attack.\n\ud83d\udd30 17. Gaining Access: client side attack.\n\ud83d\udd30 18. Client Side Attack Using Social Engineering.\n\ud83d\udd30 19. Website Hacking & Security (Advance tips & tricks).\n\ud83d\udd30 20. WordPress Website Hacking & Security (Advance tips & tricks).\n\ud83d\udd30 21. Information Tracking Using Number.\n\ud83d\udd30 22. Malware Making & Threats (virus).\n\ud83d\udd30 23. Hacking Device Making.\n\ud83d\udd30 24. Windows Attack.\n\ud83d\udd30 25. Hack Bank Account via-APT Attack.\n\ud83d\udd30 26. Black Hat Approach to Hacking.\n\n\u09ac\u09cb\u09a8\u09be\u09b8 \u0995\u09cd\u09b2\u09be\u09b8\u0983 Facebook Security & Ethical Hacking.\n\n\ud83d\ude42............\u0986\u09b0\u0993 \u0985\u09a8\u09c7\u0995 \u0995\u09bf\u099b\u09c1............\ud83d\ude42\n\n\u2753\u2753 \u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u099c\u09df\u09c7\u09a8 \u0995\u09b0\u09be\u09b0 \u09b6\u09b0\u09cd\u09a4\u0983\u2753\u2753\n\n\ud83d\udc49 \u09e7\u09eb \u09a8\u09ad\u09c7\u09ae\u09cd\u09ac\u09b0 \u09a5\u09c7\u0995\u09c7 \u0995\u09cd\u09b2\u09be\u09b8 \u09b6\u09c1\u09b0\u09c1 \u09b9\u09ac\u09c7\u0964 \u09a8\u09bf\u09df\u09ae\u09bf\u09a4 \u09b2\u09be\u0987\u09ad \u0995\u09cd\u09b2\u09be\u09b8\u09c7 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u09a5\u09be\u0995\u09a4\u09c7 \u09b9\u09ac\u09c7 \u098f\u09ac\u0982 \u09b9\u09cb\u09ae\u0993\u09df\u09be\u09b0\u09cd\u0995 \u0997\u09c1\u09b2\u09cb \u0997\u09cd\u09b0\u09c1\u09aa\u09c7 \u099c\u09ae\u09be \u09a6\u09bf\u09a4\u09c7 \u09b9\u09ac\u09c7\n\n\ud83d\udc49 \u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09af\u09be\u09ac\u09a4\u09c0\u09df \u0996\u09b0\u099a \u09aa\u09b0\u09bf\u099a\u09be\u09b2\u09a8\u09be \u0995\u09b0\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u0996\u09c1\u09ac\u0987 \u09b8\u09be\u09ae\u09be\u09a8\u09cd\u09af \u09b0\u09c7\u099c\u09bf\u09b7\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u09ab\u09bf \u09a8\u09c7\u0993\u09df\u09be \u09b9\u09ac\u09c7\u0964 \u0995\u09bf\u099b\u09c1 \u09ac\u09be\u099c\u09c7, \u0985\u09a8\u09bf\u09df\u09ae\u09bf\u09a4, \u0986\u0997\u09be\u099b\u09be \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0, \u09ab\u09cd\u09b0\u09bf \u09aa\u09be\u0987\u09df\u09be \u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u099c\u09df\u09c7\u09a8 \u0995\u09b0\u09c7 & \u09ac\u09bf\u09b6\u09c3\u0999\u09cd\u0996\u09b2\u09be \u09a4\u09c8\u09b0\u09c0 \u0995\u09b0\u09c7 \u09b8\u09ac\u09be\u09b0 \u09ae\u09be\u099d\u09c7\u0964 \u098f\u0987 \u0985\u09ae\u09a8\u09cb\u09af\u09cb\u0997\u09c0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u09ad\u09be\u09b2\u09cb \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09b0\u09be \u09b8\u09c1\u09af\u09cb\u0997 \u09aa\u09be\u09df \u09a8\u09be \u0995\u09cb\u09b0\u09cd\u09b8 \u0995\u09b0\u09be\u09b0\u0964 \u09b0\u09c7\u099c\u09bf\u09b7\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u09ab\u09bf \u09a8\u09bf\u099a\u09cd\u099b\u09bf \u09b6\u09c1\u09a7\u09c1\u09ae\u09be\u09a4\u09cd\u09b0 \u09b8\u09bf\u09b0\u09bf\u09df\u09be\u09b8 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u09b8\u09c1\u09af\u09cb\u0997 \u09a6\u09c7\u0993\u09df\u09be\u09b0 \u099c\u09a8\u09cd\u09af, \u099f\u09be\u0995\u09be \u09aa\u09df\u09b8\u09be\u09b0 \u09ac\u09bf\u09b7\u09df \u09a5\u09be\u0995\u09b2\u09c7 \u09ac\u0996\u09be\u099f\u09c7 \u0997\u09c1\u09b2\u09cb \u0986\u09b0 \u0995\u09c7\u09be\u09b0\u09cd\u09b8\u09c7 \u099c\u09df\u09c7\u09a8 \u0995\u09b0\u09ac\u09c7 \u09a8\u09be\u0964\n\n\ud83d\udc49 \u0986\u09aa\u09a8\u09bf \u0995\u09cb\u09b0\u09cd\u09b8\u099f\u09bf \u0995\u09b0\u09a4\u09c7 \u099a\u09be\u0987\u09b2\u09c7 \u09aa\u09c7\u099c\u09c7 \u09ae\u09c7\u09b8\u09c7\u099c \u09a6\u09bf\u09a8 \u0985\u09a5\u09ac\u09be \u0995\u09ae\u09c7\u09a8\u09cd\u099f \u0995\u09b0\u09c1\u09a8 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u099f\u09bf\u09ae \u09ae\u09c7\u09ae\u09cd\u09ac\u09be\u09b0 \u0986\u09aa\u09a8\u09be\u09b0 \u0987\u09a8\u09ac\u0995\u09cd\u09b8\u09c7 \u09ae\u09c7\u09b8\u09c7\u099c \u09a6\u09bf\u09df\u09c7 \u09ac\u09bf\u09b8\u09cd\u09a4\u09be\u09b0\u09bf\u09a4 \u099c\u09be\u09a8\u09be\u09ac\u09c7\u09a8 \u0964 (\u0986\u09b8\u09a8 \u09b8\u0982\u0996\u09cd\u09af\u09be \u09b8\u09c0\u09ae\u09bf\u09a4)\n\n\ud83d\udc49\ud83d\udc49 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ab\u09c7\u09b8\u09ac\u09c1\u0995 \u0997\u09cd\u09b0\u09c1\u09aa \u09b2\u09bf\u0982\u0995\u0983 https:\/\/facebook.com\/groups\/w3codevs\n\n\u0986\u09b0\u09c7\u09be \u09ac\u09bf\u09b8\u09cd\u09a4\u09be\u09b0\u09bf\u09a4 \u099c\u09be\u09a8\u09a4\u09c7 W3codevs Community \u0997\u09cd\u09b0\u09c1\u09aa\u09c7 \u099c\u09af\u09bc\u09c7\u09a8 \u0995\u09b0\u09c1\u09a8\u0964\n\n\ud83d\udc49\ud83d\udc49\u09aa\u09cd\u09b0\u09af\u09bc\u09c7\u09be\u099c\u09a8\u09c7 \u0995\u09b2 \u0995\u09b0\u09c1\u09a8 - 01752215939, 01790262300, 01568830767\n\n\u0986\u09aa\u09a8\u09bf \u0986\u09aa\u09a8\u09be\u09b0 \u09ab\u09c7\u09b8\u09ac\u09c1\u0995 \u09ac\u09a8\u09cd\u09a7\u09c1\u09a6\u09c7\u09b0\u0995\u09c7 \u0995\u09ae\u09c7\u09a8\u09cd\u099f \u09ac\u0995\u09cd\u09b8\u09c7 \u09ae\u09c7\u09a8\u09b8\u09a8 \u0995\u09b0\u09c7 \u09a6\u09bf\u09a8, \u09b9\u09df\u09a4 \u0986\u09aa\u09a8\u09be\u09b0 \u098f\u0987 \u0995\u09ae\u09c7\u09a8\u09cd\u099f \u0986\u09aa\u09a8\u09be\u09b0 \u09ac\u09a8\u09cd\u09a7\u09c1\u09b0 \u09ac\u09c7\u0995\u09be\u09b0\u09a4\u09cd\u09ac \u09a6\u09c1\u09b0 \u0995\u09b0\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u0964\n\n(\u09ac\u09bf\u0983\u09a6\u09cd\u09b0\u0983 \u098f\u0987 \u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09ae\u09c2\u09b2 \u0989\u09a6\u09cd\u09a6\u09c7\u09b6\u09cd\u09af \u09b9\u09b2, \u09b8\u0995\u09b2\u09c7 \u09af\u09be\u09a4\u09c7 \u09b8\u09be\u0987\u09ac\u09be\u09b0 \u09b8\u09bf\u0995\u09bf\u0989\u09b0\u09bf\u099f\u09bf \u09b8\u09ae\u09cd\u09aa\u09b0\u09cd\u0995\u09c7 \u099c\u09be\u09a8\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 \u098f\u09ac\u0982 \u0987\u09a5\u09bf\u0995\u09be\u09b2 \u09b9\u09cd\u09af\u09be\u0995\u09bf\u0982 \u09b6\u09bf\u0996\u09be\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u09a8\u09bf\u099c\u09c7\u09b0 \u0995\u09cd\u09af\u09be\u09b0\u09bf\u09df\u09be\u09b0 \u0997\u09dc\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 \u098f\u09ac\u0982 \u09a6\u09c7\u09b6 \u0993 \u099c\u09be\u09a4\u09bf\u09b0 \u09ae\u0999\u09cd\u0997\u09b2\u09c7 \u098f\u0987 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u0995\u09c7 \u0995\u09be\u099c\u09c7 \u09b2\u09be\u0997\u09be\u09df\u0964 \u0995\u09c7\u0989 \u098f\u0987 \u0995\u09cb\u09b0\u09cd\u09b8 \u0995\u09b0\u09be\u09b0 \u09aa\u09b0 \u0995\u09cb\u09a8 \u09aa\u09cd\u09b0\u0995\u09be\u09b0 \u0985\u09ac\u09c8\u09a7 \u09b9\u09cd\u09af\u09be\u0995\u09bf\u0982 \u098f\u09ac\u0982 \u0985\u09a8\u09c8\u09a4\u09bf\u0995 \u0995\u09cb\u09a8 \u0995\u09be\u099c \u0995\u09b0\u09c7 \u09a5\u09be\u0995\u09b2\u09c7 \u09ac\u0