ps:\/\/m.facebook.com\/mhjibon.w3codevs","__isNode":"User"},"length":8,"offset":134}],"inline_style_ranges":[],"text":"\u2705 Course Name : Responsive Web Design with Themeforest \n\u2705 Course Duration : 03 months ( weekly 03 days ) \n\u2705 Course Instructor - 01 :  Mh Jibon (Software Developer & Cyber Security Expertist)"},{"block_type":"UNSTYLED","data":"{}","depth":0,"media_alignment":null,"media_caption":null,"entity_ranges":[{"entity_type":"MENTION","entity":{"__typename":"User","__isEntity":"User","__isActor":"User","id":"100077286978950","url":"https:\/\/www.facebook.com\/fariya.w3codevs","profile_url":"https:\/\/www.facebook.com\/fariya.w3codevs","work_foreign_entity_info":null,"work_info":null,"mobileUrl":"https:\/\/m.facebook.com\/fariya.w3codevs","__isNode":"User"},"length":15,"offset":28}],"inline_style_ranges":[{"inline_style":"BOLD","length":24,"offset":76}],"text":"\u2705 Course Instructor - 02 :  Fariya Tabassum (Professional Web Designer)\n\n\n\u2705\u2705\u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u0995\u09bf \u0995\u09bf \u09b6\u09c7\u0996\u09be\u09a8\u09cb \u09b9\u09ac\u09c7\u0983\u2705\u2705\n\ud83d\udd30 1. HTML, HTML5 \n\ud83d\udd30 2. CSS, CSS3 \n\ud83d\udd30 3. JavaScript (Basic) \n\ud83d\udd30 4. jQuery (Basic to Advance) \n\ud83d\udd30 5. 100+ jQuery Plugins \n\ud83d\udd30 6. PSD to HTML \n\ud83d\udd30 7. Bootstrap 4 and Bootstrap 5 \n\ud83d\udd30 8. GitHub \n\ud83d\udd30 9. Freelancing Marketplace \n\ud83d\udd30 10. Final Project with Themeforest Submission  \n\n\n\u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u09e9\u09e6\u09e6 \u099c\u09a8 \u0986\u0997\u09cd\u09b0\u09b9\u09c0\u09a6\u09c7\u09b0 \u09a8\u09bf\u09ac\u09cb\u0964 \u0995\u09c7\u0989 \u09b6\u09bf\u0996\u09a4\u09c7 \u099a\u09be\u0987\u09b2\u09c7 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09b8 \u0995\u09b0\u09c1\u09a8, \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u09be\u09aa\u09cb\u09b0\u09cd\u099f \u09ae\u09c7\u09ae\u09cd\u09ac\u09be\u09b0\u09b0\u09be \u0986\u09aa\u09a8\u09be\u0995\u09c7 \u09ae\u09c7\u09b8\u09c7\u099e\u09cd\u099c\u09be\u09b0 \u0997\u09cd\u09b0\u09c1\u09aa\u09c7 \u098f\u09a1 \u0995\u09b0\u09c7 \u09a8\u09bf\u09ac\u09c7\u09a8\u0964  \n\n( \u0986\u09aa\u09a8\u09be\u09b0 \u09ab\u09c7\u09b8\u09ac\u09c1\u0995 \u09aa\u09cd\u09b0\u09cb\u09ab\u09be\u0987\u09b2\u09c7 \u09aa\u09cb\u09b8\u09cd\u099f\u099f\u09bf \u09b6\u09c7\u09df\u09be\u09b0 \u0995\u09b0\u09c1\u09a8 \u098f\u09ac\u0982 \u09ac\u09a8\u09cd\u09a7\u09c1\u09a6\u09c7\u09b0\u0995\u09c7 \u0995\u09ae\u09c7\u09a8\u09cd\u099f \u09ac\u0995\u09cd\u09b8\u09c7 \u09ae\u09c7\u09a8\u09b6\u09a8 \u0995\u09b0\u09c7\u09a6\u09bf\u09a8\u0964 \u09b9\u09df\u09a4 \u098f\u0987 \u09b6\u09c7\u09df\u09be\u09b0 \u098f\u09ac\u0982 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09b8 \u098f  \u0986\u09aa\u09a8\u09be\u09b0 \u09ac\u09a8\u09cd\u09a7\u09c1\u09b0 \u09ac\u09c7\u0995\u09be\u09b0\u09a4\u09cd\u09ac \u09a6\u09c1\u09b0 \u0995\u09b0\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 )\n\n"}],"__module_operation_CometFeedStoryMessageSection_story":{"__dr":"CometFeedStoryRichMessageRenderingStrategy_message$normalization.graphql"},"__module_component_CometFeedStoryMessageSection_story":{"__dr":"CometFeedStoryRichMessageRenderingStrategy.react"}},"message_suffix":null,"message_container":{"__typename":"CometFeedStoryMessageContainerRenderingStrategy","__isICometStorySection":"CometFeedStoryMessageContainerRenderingStrategy","is_prod_eligible":true,"story":{"message":{"text":"\ud83d\udce3 W3codevs Community \u2705 \u0997\u09cd\u09b0\u09c1\u09aa\u09c7\u09b0 \u09aa\u0995\u09cd\u09b7 \u09a5\u09c7\u0995\u09c7 \u0986\u09ac\u09be\u09b0\u0993 \u09a7\u09be\u09ae\u09be\u0995\u09be \u0985\u09ab\u09be\u09b0\u0964\n\n\ud83d\udce3 \u09a6\u09c0\u09b0\u09cd\u0998 \u09e9 \u09ae\u09be\u09b8\u09ac\u09cd\u09af\u09be\u09aa\u09c0 \u09e7\u09e6\u09e6\u0025 \u09ab\u09cd\u09b0\u09bf \u0985\u09a8\u09b2\u09be\u0987\u09a8 \u09b2\u09be\u0987\u09ad \u0995\u09cd\u09b2\u09be\u09b8 ( \u0995\u09cb\u09a8\u09cb \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u09ab\u09bf \u09a8\u09c7\u0993\u09df\u09be \u09b9\u09ac\u09c7 \u09a8\u09be ) \n\ud83d\udce3 \u0995\u09cb\u09b0\u09cd\u09b8\u099f\u09bf \u09b8\u09ae\u09cd\u09aa\u09c2\u09b0\u09cd\u09a3 \u09a8\u09a4\u09c1\u09a8\u09a6\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u0989\u09aa\u09af\u09cb\u0997\u09c0 \u0995\u09b0\u09c7 \u09b8\u09be\u099c\u09be\u09a8\u09cb \u09b9\u09df\u09c7\u099b\u09c7\u0964\n\n\u2705 Course Name : Responsive Web Design with Themeforest \n\u2705 Course Duration : 03 months ( weekly 03 days ) \n\u2705 Course Instructor - 01 :  Mh Jibon (Software Developer & Cyber Security Expertist)\n\n\u2705 Course Instructor - 02 :  Fariya Tabassum (Professional Web Designer)\n\n\u2705\u2705**\u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u0995\u09bf \u0995\u09bf \u09b6\u09c7\u0996\u09be\u09a8\u09cb \u09b9\u09ac\u09c7\u0983**\u2705\u2705\n\ud83d\udd30 1. HTML, HTML5 \n\ud83d\udd30 2. CSS, CSS3 \n\ud83d\udd30 3. JavaScript (Basic) \n\ud83d\udd30 4. jQuery (Basic to Advance) \n\ud83d\udd30 5. 100+ jQuery Plugins \n\ud83d\udd30 6. PSD to HTML \n\ud83d\udd30 7. Bootstrap 4 and Bootstrap 5 \n\ud83d\udd30 8. GitHub \n\ud83d\udd30 9. Freelancing Marketplace \n\ud83d\udd30 10. Final Project with Themeforest Submission  \n\n\u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u09e9\u09e6\u09e6 \u099c\u09a8 \u0986\u0997\u09cd\u09b0\u09b9\u09c0\u09a6\u09c7\u09b0 \u09a8\u09bf\u09ac\u09cb\u0964 \u0995\u09c7\u0989 \u09b6\u09bf\u0996\u09a4\u09c7 \u099a\u09be\u0987\u09b2\u09c7 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09b8 \u0995\u09b0\u09c1\u09a8, \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u09be\u09aa\u09cb\u09b0\u09cd\u099f \u09ae\u09c7\u09ae\u09cd\u09ac\u09be\u09b0\u09b0\u09be \u0986\u09aa\u09a8\u09be\u0995\u09c7 \u09ae\u09c7\u09b8\u09c7\u099e\u09cd\u099c\u09be\u09b0 \u0997\u09cd\u09b0\u09c1\u09aa\u09c7 \u098f\u09a1 \u0995\u09b0\u09c7 \u09a8\u09bf\u09ac\u09c7\u09a8\u0964  \n\n( \u0986\u09aa\u09a8\u09be\u09b0 \u09ab\u09c7\u09b8\u09ac\u09c1\u0995 \u09aa\u09cd\u09b0\u09cb\u09ab\u09be\u0987\u09b2\u09c7 \u09aa\u09cb\u09b8\u09cd\u099f\u099f\u09bf \u09b6\u09c7\u09df\u09be\u09b0 \u0995\u09b0\u09c1\u09a8 \u098f\u09ac\u0982 \u09ac\u09a8\u09cd\u09a7\u09c1\u09a6\u09c7\u09b0\u0995\u09c7 \u0995\u09ae\u09c7\u09a8\u09cd\u099f \u09ac\u0995\u09cd\u09b8\u09c7 \u09ae\u09c7\u09a8\u09b6\u09a8 \u0995\u09b0\u09c7\u09a6\u09bf\u09a8\u0964 \u09b9\u09df\u09a4 \u098f\u0987 \u09b6\u09c7\u09df\u09be\u09b0 \u098f\u09ac\u0982 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09b8 \u098f  \u0986\u09aa\u09a8\u09be\u09b0 \u09ac\u09a8\u09cd\u09a7\u09c1\u09b0 \u09ac\u09c7\u0995\u09be\u09b0\u09a4\u09cd\u09ac \u09a6\u09c1\u09b0 \u0995\u09b0\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 )"},"referenced_sticker":null,"attachments":[{"style_list":["photo","fallback"]}],"text_format_metadata":null,"comet_sections":{"message":{"__typename":"CometFeedStoryRichMessageRenderingStrategy"}},"id":"UzpfSTEwMDAwOTcwNzg1MTk1MzpWSzozMTI3OTI2OTg0MTkxMTgx"},"__module_operation_CometFeedStoryMessageContainerSection_story":{"__dr":"CometFeedStoryMessageContainerRenderingStrategy_messageContainer$normalization.graphql"},"__module_component_CometFeedStoryMessageContainerSection_story":{"__dr":"CometFeedStoryMessageContainerRenderingStrategy.react"}},"message_sticker":null},"encrypted_tracking":"AZVPP8sRJorymWcQ3MUy7aTQavvZPQSllXeC1QV639008vGWlQyIyi9KWEarY5oc7tz4E2UJYNEX_JQ10svhdqgWzHXxvwleMypj7_eABxvnq1NbxnzvZ6oud_VI0D6rqe6prBQQWeBC0kkyUYewNofafNB8SQKlayjRQqqoLpXCFo-kr7ualltERz4PFd2_Exvrc5QfRH3rezkPI9XW7d_Map8mnYf07uNlC0o9noZTMg","attachments":[{"deduplication_key":"393e46f5fdcff57c140d0c6bb8ac9904","__typename":"StoryAttachment","style_list":["photo","fallback"],"styles":{"__typename":"StoryAttachmentPhotoStyleRenderer","__isStoryAttachmentStyleRendererUnion":"StoryAttachmentPhotoStyleRenderer","is_prod_eligible":true,"attachment":{"media":{"__typename":"Photo","photo_image":{"uri":"https:\/\/scontent.fcgp27-1.fna.fbcdn.net\/v\/t39.30808-6\/274630647_1614715495528697_1833277611464145684_n.jpg?stp=dst-jpg_p180x540&_nc_cat=108&ccb=1-5&_nc_sid=5cd70e&_nc_