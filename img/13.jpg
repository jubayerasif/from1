rer":null}],"sponsored_data":null,"text_format_metadata":null,"message":{"text":"\ud83d\udce3 W3codevs Community \u2705 \u0997\u09cd\u09b0\u09c1\u09aa\u09c7\u09b0 \u09aa\u0995\u09cd\u09b7 \u09a5\u09c7\u0995\u09c7 \u0986\u09ac\u09be\u09b0\u0993 \u09a7\u09be\u09ae\u09be\u0995\u09be \u0985\u09ab\u09be\u09b0\u0964\n\n\ud83d\udce3 \u09a6\u09c0\u09b0\u09cd\u0998 \u09e9 \u09ae\u09be\u09b8\u09ac\u09cd\u09af\u09be\u09aa\u09c0 \u09e7\u09e6\u09e6\u0025 \u09ab\u09cd\u09b0\u09bf \u0985\u09a8\u09b2\u09be\u0987\u09a8 \u09b2\u09be\u0987\u09ad \u0995\u09cd\u09b2\u09be\u09b8 ( \u0995\u09cb\u09a8\u09cb \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u09ab\u09bf \u09a8\u09c7\u0993\u09df\u09be \u09b9\u09ac\u09c7 \u09a8\u09be ) \n\ud83d\udce3 \u0995\u09cb\u09b0\u09cd\u09b8\u099f\u09bf \u09b8\u09ae\u09cd\u09aa\u09c2\u09b0\u09cd\u09a3 \u09a8\u09a4\u09c1\u09a8\u09a6\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u0989\u09aa\u09af\u09cb\u0997\u09c0 \u0995\u09b0\u09c7 \u09b8\u09be\u099c\u09be\u09a8\u09cb \u09b9\u09df\u09c7\u099b\u09c7\u0964\n\n\u2705 Course Name : Responsive Web Design with Themeforest \n\u2705 Course Duration : 03 months ( weekly 03 days ) \n\u2705 Course Instructor - 01 :  Mh Jibon (Software Developer & Cyber Security Expertist)\n\n\u2705 Course Instructor - 02 :  Fariya Tabassum (Professional Web Designer)\n\n\u2705\u2705**\u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u0995\u09bf \u0995\u09bf \u09b6\u09c7\u0996\u09be\u09a8\u09cb \u09b9\u09ac\u09c7\u0983**\u2705\u2705\n\ud83d\udd30 1. HTML, HTML5 \n\ud83d\udd30 2. CSS, CSS3 \n\ud83d\udd30 3. JavaScript (Basic) \n\ud83d\udd30 4. jQuery (Basic to Advance) \n\ud83d\udd30 5. 100+ jQuery Plugins \n\ud83d\udd30 6. PSD to HTML \n\ud83d\udd30 7. Bootstrap 4 and Bootstrap 5 \n\ud83d\udd30 8. GitHub \n\ud83d\udd30 9. Freelancing Marketplace \n\ud83d\udd30 10. Final Project with Themeforest Submission  \n\n\u0995\u09cb\u09b0\u09cd\u09b8\u09c7 \u09e9\u09e6\u09e6 \u099c\u09a8 \u0986\u0997\u09cd\u09b0\u09b9\u09c0\u09a6\u09c7\u09b0 \u09a8\u09bf\u09ac\u09cb\u0964 \u0995\u09c7\u0989 \u09b6\u09bf\u0996\u09a4\u09c7 \u099a\u09be\u0987\u09b2\u09c7 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09b8 \u0995\u09b0\u09c1\u09a8, \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u09be\u09aa\u09cb\u09b0\u09cd\u099f \u09ae\u09c7\u09ae\u09cd\u09ac\u09be\u09b0\u09b0\u09be \u0986\u09aa\u09a8\u09be\u0995\u09c7 \u09ae\u09c7\u09b8\u09c7\u099e\u09cd\u099c\u09be\u09b0 \u0997\u09cd\u09b0\u09c1\u09aa\u09c7 \u098f\u09a1 \u0995\u09b0\u09c7 \u09a8\u09bf\u09ac\u09c7\u09a8\u0964  \n\n( \u0986\u09aa\u09a8\u09be\u09b0 \u09ab\u09c7\u09b8\u09ac\u09c1\u0995 \u09aa\u09cd\u09b0\u09cb\u09ab\u09be\u0987\u09b2\u09c7 \u09aa\u09cb\u09b8\u09cd\u099f\u099f\u09bf \u09b6\u09c7\u09df\u09be\u09b0 \u0995\u09b0\u09c1\u09a8 \u098f\u09ac\u0982 \u09ac\u09a8\u09cd\u09a7\u09c1\u09a6\u09c7\u09b0\u0995\u09c7 \u0995\u09ae\u09c7\u09a8\u09cd\u099f \u09ac\u0995\u09cd\u09b8\u09c7 \u09ae\u09c7\u09a8\u09b6\u09a8 \u0995\u09b0\u09c7\u09a6\u09bf\u09a8\u0964 \u09b9\u09df\u09a4 \u098f\u0987 \u09b6\u09c7\u09df\u09be\u09b0 \u098f\u09ac\u0982 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09b8 \u098f  \u0986\u09aa\u09a8\u09be\u09b0 \u09ac\u09a8\u09cd\u09a7\u09c1\u09b0 \u09ac\u09c7\u0995\u09be\u09b0\u09a4\u09cd\u09ac \u09a6\u09c1\u09b0 \u0995\u09b0\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 )"},"is_text_only_story":false,"id":"UzpfSTEwMDAwOTcwNzg1MTk1MzpWSzozMTI3OTI2OTg0MTkxMTgx"},"__module_operation_CometFeedStoryAttachedStory_story":{"__dr":"CometFeedStoryInvertedAttachedStoryLayoutStrategy_attachedStoryLayout$normalization.graphql"},"__module_component_CometFeedStoryAttachedStory_story":{"__dr":"CometFeedStoryInvertedAttachedStoryLayoutStrategy.react"}},"attached_story":null}},"id":"UzpfSTEwNzg5MTE1NDI3MzA4Nzo0ODgxNjk3MTI5MTE4OTQ="},"__module_operation_CometFeedStoryAttachedStorySection_story":{"__dr":"CometFeedStoryAttachedStoryStrategy_attachedStory$normalization.graphql"},"__module_component_CometFeedStoryAttachedStorySection_story":{"__dr":"CometFeedStoryAttachedStoryStrategy.react"}